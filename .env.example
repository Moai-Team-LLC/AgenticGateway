# --- Control plane (AgenticGateway edge) ---
# Port the edge listens on.
AGW_PORT=8787
# SQLite control-plane store (keys, vault, budgets, ledger, routing policy).
AGW_DB_PATH=./data/agw.db
# Bifrost data plane base URL (docker compose default).
BIFROST_URL=http://localhost:8080
# Vault master key: 64 hex chars (32 bytes). Generate: openssl rand -hex 32
# Encrypts per-tenant upstream credentials at rest. Required for vault commands.
AGW_VAULT_KEY=
# Read-only admin endpoints bearer token (GET /admin/*). Empty = admin disabled.
AGW_ADMIN_TOKEN=

# --- Fail-closed knobs ---
# Require a vaulted upstream credential (Bifrost virtual key) per tenant.
# true in production (Bifrost governance on); false for keyless local Bifrost.
AGW_REQUIRE_VK=false
# Per-run default cost ceiling (USD) when a run has no explicit budget.
AGW_RUN_LIMIT_USD=5

# --- Guard (vendored from AgenticMind — do not tune away) ---
# Max input chars before fail-closed "too_long" (gateway default is generous;
# AgenticMind's own surface uses 8000).
AGW_GUARD_MAX_CHARS=512000

# --- Cache (exact, control-plane side; semantic cache lives in Bifrost) ---
AGW_CACHE_TTL_MS=300000
AGW_CACHE_MAX_ENTRIES=1024

# --- Evidence (hash-not-text, AIUC-1 lane) ---
# file | http | off. "http" posts to the AgenticMind /hooks/audit contract.
AGW_EVIDENCE_SINK=file
AGW_EVIDENCE_FILE=./data/evidence.jsonl
# Only for AGW_EVIDENCE_SINK=http:
AGW_AUDIT_URL=
AGW_AUDIT_TOKEN=

# --- Delegation: judge sampling (AgenticPerformance contract) ---
# Deterministic sample rate for async judge on high-risk routes. 0 disables.
AGW_JUDGE_SAMPLE_RATE=0.05
# provider-prefixed model routed through Bifrost for judge calls.
AGW_JUDGE_MODEL=openai/gpt-4o-mini

# --- Protected paths (AgenticAssurance pack) --- report | block
AGW_PROTECTED_PATH_MODE=report

# Optional price-table override (JSON: { "provider/model": {inPerMTok, outPerMTok} }).
# Merges over the built-in table; unset = built-in only.
AGW_PRICE_FILE=

# --- Cost anomaly detection ---
# Alert when 5-minute spend exceeds trailing-hour average by this factor.
AGW_ANOMALY_FACTOR=5
# Throttle the offending key automatically on anomaly (true/false).
AGW_ANOMALY_THROTTLE=false

# --- OTel export (cost-per-outcome → same traces as AgenticPerformance) ---
# OTLP/JSON traces endpoint, e.g. APL ingest: http://localhost:4319/v1/traces
APL_INGEST_URL=
APL_INGEST_TOKEN=

# --- Data plane (consumed by docker compose in ./bifrost) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
